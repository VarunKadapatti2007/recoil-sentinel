# ============================================================================
# Recoil environment — copy to .env (or export) and fill in what you have.
# THE CORE RUNS WITH NOTHING SET: no key -> deterministic mock judge + cached
# verdicts, and the entire demo works offline.
# ============================================================================

# ----------------------------------------------------------------------------
# REQUIRED (for live judging; optional for the cached/mock demo path)
# ----------------------------------------------------------------------------

# Which judge grades agent outputs: anthropic | bedrock | openai | mock
# Anything unconfigured degrades safely to the deterministic mock judge.
RECOIL_JUDGE_PROVIDER=anthropic

# Anthropic API key (https://console.anthropic.com). Enables the live judge
# and the live agent-under-test path.
ANTHROPIC_API_KEY=

# Judge model. Default is the current strongest Claude model.
RECOIL_JUDGE_MODEL=claude-opus-4-8

# ----------------------------------------------------------------------------
# OPTIONAL — demo determinism
# ----------------------------------------------------------------------------

# true (default): the gate serves real, previously-computed judge verdicts
# from cache so the live demo never depends on network/model variance.
# Set false to judge live on every gate run.
RECOIL_DEMO_MODE=true

# Model used by the demo triage agent when calling the live API.
RECOIL_AGENT_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------------------
# OPTIONAL — AWS Bedrock judge provider (RECOIL_JUDGE_PROVIDER=bedrock)
# ----------------------------------------------------------------------------
# Uses the standard AWS credential chain (env vars, ~/.aws, instance role).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
# Bedrock model ids carry the `anthropic.` prefix.
RECOIL_BEDROCK_MODEL_ID=anthropic.claude-opus-4-8

# ----------------------------------------------------------------------------
# OPTIONAL — OpenAI judge provider (RECOIL_JUDGE_PROVIDER=openai)
# ----------------------------------------------------------------------------
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# OPTIONAL — spoken verdicts (ElevenLabs). Pre-rendered to MP3 during seeding;
# the demo never waits on this layer. Absent key = silent no-op.
# ----------------------------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ----------------------------------------------------------------------------
# OPTIONAL — adapters (working local defaults; see README integration table)
# ----------------------------------------------------------------------------
# Ground-truth source for the judge: local (JSON store, default) | airbyte
RECOIL_GROUND_TRUTH_PROVIDER=local
# Publish target: local (Recoil version store, default) | guild
RECOIL_PUBLISH_TARGET=local

# ----------------------------------------------------------------------------
# SENTINEL PHASES B-E — sponsor integrations (see HANDOFF.md / RECOIL_SENTINEL_PLAN.md)
# Collect these per the setup guide; paste real values into .env (gitignored), NOT here.
# ----------------------------------------------------------------------------
# x402 / Coinbase Developer Platform (Phase E — payments)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
X402_WALLET_ADDRESS=
X402_NETWORK=base-sepolia

# Senso / cited.md (publish verified reports to the agentic content layer —
# REQUIRED for the hackathon's "publish to cited.md" eligibility). Get a key at
# https://senso.ai / https://docs.senso.ai (Hello World guide).
SENSO_API_KEY=

# Composio (Phase D — real web actions: GitHub/Slack)
COMPOSIO_API_KEY=

# ClickHouse Cloud (Phase C — trace/eval storage + analytics)
CLICKHOUSE_HOST=
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Airbyte (Phase B — ground-truth ingestion)
AIRBYTE_API_KEY=
AIRBYTE_WORKSPACE_ID=

# ----------------------------------------------------------------------------
# OPTIONAL — plumbing (pinned ports; change only if you must)
# ----------------------------------------------------------------------------
RECOIL_API_PORT=8787
RECOIL_WEB_PORT=3000
# Where the dashboard reaches the API (browser-side).
NEXT_PUBLIC_RECOIL_API=http://localhost:8787
# Timeouts/retries for every external call.
RECOIL_EXTERNAL_TIMEOUT_S=20
RECOIL_EXTERNAL_RETRIES=2
